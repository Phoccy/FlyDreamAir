-- FlyDreamAir Lounge Management System
-- Version: 1.0
-- Author: Adam Masters - Systems Architect

SET SQL_MODE = "NO_AUTO_VALUE_ON_ZERO";
START TRANSACTION;

-- 1. Lounges Table
CREATE TABLE IF NOT EXISTS `lounges` (
  `lounge_id` varchar(10) NOT NULL,
  `airport_code` char(3) NOT NULL, -- e.g., SYD, MEL
  `name` varchar(100) NOT NULL,
  `capacity` int(11) NOT NULL,
  `current_occupancy` int(11) DEFAULT 0,
  PRIMARY KEY (`lounge_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 2. Bookings Table
CREATE TABLE IF NOT EXISTS `bookings` (
  `booking_id` int(11) NOT NULL AUTO_INCREMENT,
  `user_id` varchar(50) NOT NULL, -- Membership Number
  `lounge_id` varchar(10) NOT NULL,
  `booking_date` date NOT NULL,
  `status` enum('confirmed','cancelled','checked-in') DEFAULT 'confirmed',
  PRIMARY KEY (`booking_id`),
  FOREIGN KEY (`lounge_id`) REFERENCES `lounges`(`lounge_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

COMMIT;