<script>
window.onscroll = function() {
    const stickyBar = document.querySelector('.sticky-navbar');
    const heroTitle = document.querySelector('.hero-content h1');
    
    // Trigger when the bottom of the H1 passes the top of the screen
    if (window.scrollY > heroTitle.offsetTop + heroTitle.offsetHeight) {
        stickyBar.classList.add('is-active');
    } else {
        stickyBar.classList.remove('is-active');
    }
};    
</script>